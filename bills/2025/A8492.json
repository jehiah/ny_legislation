 "Sponsors":[{"ID":484,"Name":"David Weprin","Short":"WEPRIN"},{"ID":675,"Name":"Phil Steck","Short":"STECK"}],
 "Title":"Requires the development and implementation of a tattoo policy by law enforcement agencies",
 "Summary":"Requires the commissioner of the division of criminal justice services, the superintendent of the division of state police, and the commissioner of the department of corrections and community supervision and the person in charge of every state law enforcement agency to adopt and implement a tattoo policy for all members of such law enforcement agency who are designated as police officers, peace officers and applicants for employment in such positions.",
 "LawSection":"Executive Law","LawCode":"Add §837-aa, Exec L",
 "ActClause":"AN ACT to amend the executive law, in relation to requiring state law enforcement agencies to develop and implement a tattoo policy",
 "SameAsPrintNo":"S8021-2025"
}